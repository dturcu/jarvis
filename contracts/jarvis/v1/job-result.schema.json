      "type": "array",
      "items": {
        "$ref": "https://jarvis.contracts.local/jarvis/v1/common.schema.json#/$defs/log_entry"
      }
    },
    "metrics": {
      "$ref": "https://jarvis.contracts.local/jarvis/v1/common.schema.json#/$defs/metrics"
    }
  },
  "allOf": [
    {
      "if": {
        "properties": {
          "status": {
            "const": "failed"
          }
        }
      },
      "then": {
        "required": [
          "error"
        ]
      }
    },
    {
      "if": {
        "properties": {
          "status": {
            "const": "awaiting_approval"
          }
        }
      },
      "then": {
        "required": [
          "approval_id"
        ]
      }
    },
    {
      "if": {
        "properties": {
          "status": {
            "const": "completed"
          }
        }
      },
      "then": {
        "required": [
          "structured_output"
        ]
      }
    }
  ],
