{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://jarvis.contracts.local/jarvis/v1/tool-response.schema.json",
  "title": "Jarvis Tool Response",
  "type": "object",
  "required": [
    "contract_version",
    "status",
    "summary"
  ],
  "properties": {
    "contract_version": {
      "$ref": "https://jarvis.contracts.local/jarvis/v1/common.schema.json#/$defs/contract_version"
    },
    "status": {
      "$ref": "https://jarvis.contracts.local/jarvis/v1/common.schema.json#/$defs/tool_status"
    },
    "summary": {
      "$ref": "https://jarvis.contracts.local/jarvis/v1/common.schema.json#/$defs/non_empty_string"
    },
    "job_id": {
      "$ref": "https://jarvis.contracts.local/jarvis/v1/common.schema.json#/$defs/uuid"
    },
    "approval_id": {
      "$ref": "https://jarvis.contracts.local/jarvis/v1/common.schema.json#/$defs/non_empty_string"
    },
    "artifacts": {
      "type": "array",
      "items": {
        "$ref": "https://jarvis.contracts.local/jarvis/v1/common.schema.json#/$defs/artifact_record"
      }
    },
    "structured_output": {
      "type": "object"
    },
    "error": {
      "$ref": "https://jarvis.contracts.local/jarvis/v1/common.schema.json#/$defs/job_error"
    },
    "logs": {
      "type": "array",
      "items": {
        "$ref": "https://jarvis.contracts.local/jarvis/v1/common.schema.json#/$defs/log_entry"
      }
    },
    "metrics": {
      "$ref": "https://jarvis.contracts.local/jarvis/v1/common.schema.json#/$defs/metrics"
    }
  },
  "allOf": [
    {
      "if": {
        "properties": {
          "status": {
            "const": "failed"
          }
        }
      },
      "then": {
        "required": [
          "error"
        ]
      }
    },
    {
      "if": {
        "properties": {
          "status": {
            "const": "awaiting_approval"
          }
        }
      },
      "then": {
        "required": [
          "approval_id"
        ]
      }
    }
  ],
  "additionalProperties": false
}
