{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://jarvis.contracts.local/jarvis/v1/browser-job-types.schema.json",
  "title": "Jarvis Browser Job Types",
  "type": "object",
  "$defs": {
    "string_array": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "browser_viewport": {
      "type": "object",
      "required": [
        "width",
        "height"
      ],
      "properties": {
        "width": {
          "type": "integer",
          "minimum": 320
        },
        "height": {
          "type": "integer",
          "minimum": 240
        }
      },
      "additionalProperties": false
    },
    "browser_run_task_input": {
      "type": "object",
      "required": [
        "task"
      ],
      "properties": {
        "task": {
          "type": "string",
          "minLength": 1
        },
        "start_url": {
          "type": "string",
          "format": "uri"
        },
        "allowed_domains": {
          "$ref": "#/$defs/string_array"
        },
        "capture_evidence": {
          "type": "boolean"
        },
        "allow_authenticated_session": {
          "type": "boolean"
        },
        "max_steps": {
          "type": "integer",
          "minimum": 1,
          "maximum": 100
        },
        "output_name": {
          "type": "string",
          "minLength": 1
        }
      },
      "additionalProperties": false
    },
    "browser_run_task_output": {
      "type": "object",
      "required": [
        "steps_completed",
        "warnings"
      ],
      "properties": {
        "final_url": {
          "type": "string",
          "format": "uri"
        },
        "steps_completed": {
          "type": "integer",
          "minimum": 0
        },
        "extracted_data": {
          "type": "object"
        },
        "evidence_artifact_ids": {
          "$ref": "#/$defs/string_array"
        },
        "warnings": {
          "$ref": "#/$defs/string_array"
        }
      },
      "additionalProperties": false
    },
    "browser_extract_input": {
      "type": "object",
      "required": [
        "targets",
        "extraction_mode"
      ],
      "properties": {
        "targets": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "format": "uri"
          }
        },
        "extraction_mode": {
          "type": "string",
          "enum": [
            "text",
            "links",
            "tables",
            "structured"
          ]
        },
        "selectors": {
          "$ref": "#/$defs/string_array"
        },
        "follow_pagination": {
          "type": "boolean"
        },
        "max_pages": {
          "type": "integer",
          "minimum": 1,
          "maximum": 100
        },
        "output_name": {
          "type": "string",
          "minLength": 1
        }
      },
      "additionalProperties": false
    },
    "browser_extract_document": {
      "type": "object",
      "required": [
        "source_url",
        "title"
      ],
      "properties": {
        "source_url": {
          "type": "string",
          "format": "uri"
        },
        "title": {
          "type": "string",
          "minLength": 1
        },
        "content_text": {
          "type": "string"
        },
        "links": {
          "$ref": "#/$defs/string_array"
        },
        "tables_found": {
          "type": "integer",
          "minimum": 0
        }
      },
      "additionalProperties": false
    },
    "browser_extract_output": {
      "type": "object",
      "required": [
        "documents"
      ],
      "properties": {
        "documents": {
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "#/$defs/browser_extract_document"
          }
        },
        "export_artifact_id": {
          "type": "string",
          "minLength": 1
        }
      },
      "additionalProperties": false
    },
    "browser_capture_input": {
      "type": "object",
      "required": [
        "target_url",
        "mode",
        "output_name"
      ],
      "properties": {
        "target_url": {
          "type": "string",
          "format": "uri"
        },
        "mode": {
          "type": "string",
          "enum": [
            "screenshot",
            "pdf",
            "mhtml"
          ]
        },
        "full_page": {
          "type": "boolean"
        },
        "viewport": {
          "$ref": "#/$defs/browser_viewport"
        },
        "wait_until": {
          "type": "string",
          "enum": [
            "load",
            "domcontentloaded",
            "networkidle"
          ]
        },
        "output_name": {
          "type": "string",
          "minLength": 1
        }
      },
      "additionalProperties": false
    },
    "browser_capture_output": {
      "type": "object",
      "required": [
        "capture_artifact_id",
        "content_type",
        "bytes",
        "page_title"
      ],
      "properties": {
        "capture_artifact_id": {
          "type": "string",
          "minLength": 1
        },
        "content_type": {
          "type": "string",
          "minLength": 1
        },
        "bytes": {
          "type": "integer",
          "minimum": 0
        },
        "page_title": {
          "type": "string",
          "minLength": 1
        }
      },
      "additionalProperties": false
    },
    "browser_download_input": {
      "type": "object",
      "required": [
        "source_url"
      ],
      "properties": {
        "source_url": {
          "type": "string",
          "format": "uri"
        },
        "expected_kind": {
          "type": "string",
          "enum": [
            "auto",
            "pdf",
            "image",
            "xlsx",
            "csv",
            "zip",
            "docx",
            "pptx",
            "html",
            "json",
            "text",
            "binary"
          ]
        },
        "output_name": {
          "type": "string",
          "minLength": 1
        },
        "allowed_content_types": {
          "$ref": "#/$defs/string_array"
        },
        "checksum_sha256": {
          "type": "string",
          "pattern": "^[a-fA-F0-9]{64}$"
        }
      },
      "additionalProperties": false
    },
    "browser_download_output": {
      "type": "object",
      "required": [
        "downloaded_artifact_id",
        "resolved_url",
        "content_type",
        "bytes"
      ],
      "properties": {
        "downloaded_artifact_id": {
          "type": "string",
          "minLength": 1
        },
        "resolved_url": {
          "type": "string",
          "format": "uri"
        },
        "content_type": {
          "type": "string",
          "minLength": 1
        },
        "bytes": {
          "type": "integer",
          "minimum": 0
        },
        "checksum_sha256": {
          "type": "string",
          "pattern": "^[a-fA-F0-9]{64}$"
        }
      },
      "additionalProperties": false
    }
  }
}
