{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://jarvis.contracts.local/jarvis/v1/system-job-types.schema.json",
  "title": "Jarvis System Job Types",
  "type": "object",
  "$defs": {
    "cpu_core_stat": {
      "type": "object",
      "required": ["core", "usage_percent"],
      "properties": {
        "core": {
          "type": "integer",
          "minimum": 0
        },
        "usage_percent": {
          "type": "number",
          "minimum": 0,
          "maximum": 100
        },
        "frequency_mhz": {
          "type": "number",
          "exclusiveMinimum": 0
        }
      },
      "additionalProperties": false
    },
    "process_entry": {
      "type": "object",
      "required": ["pid", "name", "cpu_percent", "memory_mb", "status"],
      "properties": {
        "pid": {
          "type": "integer",
          "minimum": 1
        },
        "name": {
          "type": "string",
          "minLength": 1
        },
        "cpu_percent": {
          "type": "number",
          "minimum": 0
        },
        "memory_mb": {
          "type": "number",
          "minimum": 0
        },
        "status": {
          "type": "string",
          "minLength": 1
        },
        "user": {
          "type": "string",
          "minLength": 1
        },
        "executable": {
          "type": "string",
          "minLength": 1
        }
      },
      "additionalProperties": false
    },
    "disk_partition": {
      "type": "object",
      "required": ["mount_point", "total_bytes", "used_bytes", "free_bytes", "use_percent"],
      "properties": {
        "mount_point": {
          "type": "string",
          "minLength": 1
        },
        "device": {
          "type": "string",
          "minLength": 1
        },
        "fs_type": {
          "type": "string",
          "minLength": 1
        },
        "total_bytes": {
          "type": "integer",
          "minimum": 0
        },
        "used_bytes": {
          "type": "integer",
          "minimum": 0
        },
        "free_bytes": {
          "type": "integer",
          "minimum": 0
        },
        "use_percent": {
          "type": "number",
          "minimum": 0,
          "maximum": 100
        }
      },
      "additionalProperties": false
    },
    "network_interface_stat": {
      "type": "object",
      "required": ["name", "bytes_sent", "bytes_recv", "packets_sent", "packets_recv"],
      "properties": {
        "name": {
          "type": "string",
          "minLength": 1
        },
        "bytes_sent": {
          "type": "integer",
          "minimum": 0
        },
        "bytes_recv": {
          "type": "integer",
          "minimum": 0
        },
        "packets_sent": {
          "type": "integer",
          "minimum": 0
        },
        "packets_recv": {
          "type": "integer",
          "minimum": 0
        },
        "errors_in": {
          "type": "integer",
          "minimum": 0
        },
        "errors_out": {
          "type": "integer",
          "minimum": 0
        },
        "speed_mbps": {
          "type": "number",
          "minimum": 0
        },
        "is_up": {
          "type": "boolean"
        }
      },
      "additionalProperties": false
    },
    "system_monitor_cpu_input": {
      "type": "object",
      "properties": {
        "per_core": {
          "type": "boolean"
        }
      },
      "additionalProperties": false
    },
    "system_monitor_cpu_output": {
      "type": "object",
      "required": ["observed_at", "usage_percent", "core_count", "logical_count"],
      "properties": {
        "observed_at": {
          "type": "string",
          "format": "date-time"
        },
        "usage_percent": {
          "type": "number",
          "minimum": 0,
          "maximum": 100
        },
        "core_count": {
          "type": "integer",
          "minimum": 1
        },
        "logical_count": {
          "type": "integer",
          "minimum": 1
        },
        "frequency_mhz": {
          "type": "number",
          "exclusiveMinimum": 0
        },
        "per_core": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/cpu_core_stat"
          }
        }
      },
      "additionalProperties": false
    },
    "system_monitor_memory_input": {
      "type": "object",
      "properties": {
        "top_n": {
          "type": "integer",
          "minimum": 1
        }
      },
      "additionalProperties": false
    },
    "system_monitor_memory_output": {
      "type": "object",
      "required": ["observed_at", "total_bytes", "available_bytes", "used_bytes", "use_percent"],
      "properties": {
        "observed_at": {
          "type": "string",
          "format": "date-time"
        },
        "total_bytes": {
          "type": "integer",
          "minimum": 0
        },
        "available_bytes": {
          "type": "integer",
          "minimum": 0
        },
        "used_bytes": {
          "type": "integer",
          "minimum": 0
        },
        "use_percent": {
          "type": "number",
          "minimum": 0,
          "maximum": 100
        },
        "swap_total_bytes": {
          "type": "integer",
          "minimum": 0
        },
        "swap_used_bytes": {
          "type": "integer",
          "minimum": 0
        },
        "swap_use_percent": {
          "type": "number",
          "minimum": 0,
          "maximum": 100
        },
        "top_consumers": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/process_entry"
          }
        }
      },
      "additionalProperties": false
    },
    "system_monitor_disk_input": {
      "type": "object",
      "properties": {
        "path": {
          "type": "string",
          "minLength": 1
        }
      },
      "additionalProperties": false
    },
    "system_monitor_disk_output": {
      "type": "object",
      "required": ["observed_at", "partitions"],
      "properties": {
        "observed_at": {
          "type": "string",
          "format": "date-time"
        },
        "partitions": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/disk_partition"
          },
          "minItems": 1
        }
      },
      "additionalProperties": false
    },
    "system_monitor_network_input": {
      "type": "object",
      "properties": {
        "interface_name": {
          "type": "string",
          "minLength": 1
        }
      },
      "additionalProperties": false
    },
    "system_monitor_network_output": {
      "type": "object",
      "required": ["observed_at", "interfaces"],
      "properties": {
        "observed_at": {
          "type": "string",
          "format": "date-time"
        },
        "interfaces": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/network_interface_stat"
          },
          "minItems": 1
        }
      },
      "additionalProperties": false
    },
    "system_monitor_battery_input": {
      "type": "object",
      "additionalProperties": false
    },
    "system_monitor_battery_output": {
      "type": "object",
      "required": ["observed_at", "present"],
      "properties": {
        "observed_at": {
          "type": "string",
          "format": "date-time"
        },
        "present": {
          "type": "boolean"
        },
        "percent": {
          "type": "number",
          "minimum": 0,
          "maximum": 100
        },
        "status": {
          "type": "string",
          "enum": ["charging", "discharging", "full", "unknown"]
        },
        "seconds_left": {
          "type": "integer",
          "minimum": 0
        },
        "power_plugged": {
          "type": "boolean"
        }
      },
      "additionalProperties": false
    },
    "system_list_processes_input": {
      "type": "object",
      "properties": {
        "sort_by": {
          "type": "string",
          "enum": ["cpu", "memory", "name"]
        },
        "top_n": {
          "type": "integer",
          "minimum": 1
        },
        "name_contains": {
          "type": "string",
          "minLength": 1
        }
      },
      "additionalProperties": false
    },
    "system_list_processes_output": {
      "type": "object",
      "required": ["observed_at", "total_count", "processes"],
      "properties": {
        "observed_at": {
          "type": "string",
          "format": "date-time"
        },
        "total_count": {
          "type": "integer",
          "minimum": 0
        },
        "processes": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/process_entry"
          }
        }
      },
      "additionalProperties": false
    },
    "system_kill_process_input": {
      "type": "object",
      "properties": {
        "pid": {
          "type": "integer",
          "minimum": 1
        },
        "name": {
          "type": "string",
          "minLength": 1
        },
        "force": {
          "type": "boolean"
        }
      },
      "anyOf": [
        { "required": ["pid"] },
        { "required": ["name"] }
      ],
      "additionalProperties": false
    },
    "system_kill_process_output": {
      "type": "object",
      "required": ["killed", "pid"],
      "properties": {
        "killed": {
          "type": "boolean"
        },
        "pid": {
          "type": "integer",
          "minimum": 1
        },
        "name": {
          "type": "string",
          "minLength": 1
        },
        "signal_sent": {
          "type": "string",
          "minLength": 1
        }
      },
      "additionalProperties": false
    },
    "system_hardware_info_input": {
      "type": "object",
      "properties": {
        "components": {
          "type": "array",
          "items": {
            "type": "string",
            "enum": ["cpu", "gpu", "memory", "disk", "network", "display", "battery"]
          },
          "minItems": 1,
          "uniqueItems": true
        }
      },
      "additionalProperties": false
    },
    "system_hardware_info_output": {
      "type": "object",
      "required": ["observed_at"],
      "properties": {
        "observed_at": {
          "type": "string",
          "format": "date-time"
        },
        "cpu": {
          "type": "object",
          "required": ["model", "physical_cores", "logical_cores"],
          "properties": {
            "model": {
              "type": "string",
              "minLength": 1
            },
            "physical_cores": {
              "type": "integer",
              "minimum": 1
            },
            "logical_cores": {
              "type": "integer",
              "minimum": 1
            },
            "base_frequency_mhz": {
              "type": "number",
              "exclusiveMinimum": 0
            },
            "architecture": {
              "type": "string",
              "minLength": 1
            }
          },
          "additionalProperties": false
        },
        "gpu": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["name"],
            "properties": {
              "name": {
                "type": "string",
                "minLength": 1
              },
              "vendor": {
                "type": "string",
                "minLength": 1
              },
              "vram_bytes": {
                "type": "integer",
                "minimum": 0
              },
              "driver_version": {
                "type": "string",
                "minLength": 1
              }
            },
            "additionalProperties": false
          }
        },
        "memory": {
          "type": "object",
          "required": ["total_bytes"],
          "properties": {
            "total_bytes": {
              "type": "integer",
              "minimum": 0
            },
            "speed_mhz": {
              "type": "number",
              "exclusiveMinimum": 0
            },
            "type": {
              "type": "string",
              "minLength": 1
            },
            "slots_used": {
              "type": "integer",
              "minimum": 0
            },
            "slots_total": {
              "type": "integer",
              "minimum": 0
            }
          },
          "additionalProperties": false
        },
        "disk": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["device", "total_bytes"],
            "properties": {
              "device": {
                "type": "string",
                "minLength": 1
              },
              "model": {
                "type": "string",
                "minLength": 1
              },
              "total_bytes": {
                "type": "integer",
                "minimum": 0
              },
              "type": {
                "type": "string",
                "enum": ["ssd", "hdd", "nvme", "unknown"]
              }
            },
            "additionalProperties": false
          }
        },
        "network": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["name"],
            "properties": {
              "name": {
                "type": "string",
                "minLength": 1
              },
              "mac_address": {
                "type": "string",
                "minLength": 1
              },
              "type": {
                "type": "string",
                "minLength": 1
              },
              "speed_mbps": {
                "type": "number",
                "minimum": 0
              }
            },
            "additionalProperties": false
          }
        },
        "display": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["name", "width", "height"],
            "properties": {
              "name": {
                "type": "string",
                "minLength": 1
              },
              "width": {
                "type": "integer",
                "minimum": 1
              },
              "height": {
                "type": "integer",
                "minimum": 1
              },
              "refresh_rate_hz": {
                "type": "number",
                "exclusiveMinimum": 0
              },
              "is_primary": {
                "type": "boolean"
              }
            },
            "additionalProperties": false
          }
        },
        "battery": {
          "type": "object",
          "required": ["present"],
          "properties": {
            "present": {
              "type": "boolean"
            },
            "design_capacity_mwh": {
              "type": "number",
              "minimum": 0
            },
            "full_capacity_mwh": {
              "type": "number",
              "minimum": 0
            },
            "cycle_count": {
              "type": "integer",
              "minimum": 0
            },
            "manufacturer": {
              "type": "string",
              "minLength": 1
            }
          },
          "additionalProperties": false
        }
      },
      "additionalProperties": false
    }
  }
}
