{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://jarvis.contracts.local/jarvis/v1/agent-job-types.schema.json",
  "title": "Jarvis Agent Job Types",
  "type": "object",
  "$defs": {
    "agent_start_input": {
      "type": "object",
      "required": ["agent_id", "trigger_kind"],
      "properties": {
        "agent_id": {
          "type": "string",
          "minLength": 1
        },
        "goal": {
          "type": "string",
          "minLength": 1
        },
        "trigger_kind": {
          "type": "string",
          "enum": ["manual", "schedule", "event", "threshold"]
        },
        "cron": {
          "type": "string",
          "minLength": 1
        },
        "event_type": {
          "type": "string",
          "minLength": 1
        },
        "alert_id": {
          "type": "string",
          "minLength": 1
        }
      },
      "additionalProperties": false
    },
    "agent_start_output": {
      "type": "object",
      "required": ["run_id", "agent_id", "status", "started_at"],
      "properties": {
        "run_id": {
          "type": "string",
          "minLength": 1
        },
        "agent_id": {
          "type": "string",
          "minLength": 1
        },
        "status": {
          "type": "string",
          "enum": ["planning", "executing", "awaiting_approval", "completed", "failed", "paused"]
        },
        "goal": {
          "type": "string",
          "minLength": 1
        },
        "started_at": {
          "type": "string",
          "format": "date-time"
        }
      },
      "additionalProperties": false
    },
    "agent_step_input": {
      "type": "object",
      "required": ["run_id", "action"],
      "properties": {
        "run_id": {
          "type": "string",
          "minLength": 1
        },
        "action": {
          "type": "string",
          "minLength": 1
        },
        "input": {
          "type": "object"
        }
      },
      "additionalProperties": false
    },
    "agent_step_output": {
      "type": "object",
      "required": ["run_id", "step", "action", "status"],
      "properties": {
        "run_id": {
          "type": "string",
          "minLength": 1
        },
        "step": {
          "type": "integer",
          "minimum": 0
        },
        "action": {
          "type": "string",
          "minLength": 1
        },
        "status": {
          "type": "string",
          "enum": ["completed", "failed", "awaiting_approval"]
        },
        "output": {
          "type": "object"
        },
        "reasoning": {
          "type": "string",
          "minLength": 1
        }
      },
      "additionalProperties": false
    },
    "agent_status_input": {
      "type": "object",
      "required": ["agent_id"],
      "properties": {
        "agent_id": {
          "type": "string",
          "minLength": 1
        },
        "run_id": {
          "type": "string",
          "minLength": 1
        }
      },
      "additionalProperties": false
    },
    "agent_status_output": {
      "type": "object",
      "required": ["agent_id", "active_runs"],
      "properties": {
        "agent_id": {
          "type": "string",
          "minLength": 1
        },
        "active_runs": {
          "type": "integer",
          "minimum": 0
        },
        "runs": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["run_id", "status", "started_at"],
            "properties": {
              "run_id": {
                "type": "string",
                "minLength": 1
              },
              "status": {
                "type": "string",
                "enum": ["idle", "planning", "executing", "awaiting_approval", "completed", "failed", "paused"]
              },
              "goal": {
                "type": "string",
                "minLength": 1
              },
              "current_step": {
                "type": "integer",
                "minimum": 0
              },
              "total_steps": {
                "type": "integer",
                "minimum": 0
              },
              "started_at": {
                "type": "string",
                "format": "date-time"
              },
              "completed_at": {
                "type": "string",
                "format": "date-time"
              },
              "error": {
                "type": "string",
                "minLength": 1
              }
            },
            "additionalProperties": false
          }
        }
      },
      "additionalProperties": false
    },
    "agent_pause_input": {
      "type": "object",
      "required": ["run_id"],
      "properties": {
        "run_id": {
          "type": "string",
          "minLength": 1
        }
      },
      "additionalProperties": false
    },
    "agent_pause_output": {
      "type": "object",
      "required": ["run_id", "status", "updated_at"],
      "properties": {
        "run_id": {
          "type": "string",
          "minLength": 1
        },
        "status": {
          "type": "string",
          "const": "paused"
        },
        "updated_at": {
          "type": "string",
          "format": "date-time"
        }
      },
      "additionalProperties": false
    },
    "agent_resume_input": {
      "type": "object",
      "required": ["run_id"],
      "properties": {
        "run_id": {
          "type": "string",
          "minLength": 1
        }
      },
      "additionalProperties": false
    },
    "agent_resume_output": {
      "type": "object",
      "required": ["run_id", "status", "updated_at"],
      "properties": {
        "run_id": {
          "type": "string",
          "minLength": 1
        },
        "status": {
          "type": "string",
          "const": "executing"
        },
        "updated_at": {
          "type": "string",
          "format": "date-time"
        }
      },
      "additionalProperties": false
    },
    "agent_configure_input": {
      "type": "object",
      "required": ["agent_id"],
      "properties": {
        "agent_id": {
          "type": "string",
          "minLength": 1
        },
        "label": {
          "type": "string",
          "minLength": 1
        },
        "system_prompt": {
          "type": "string",
          "minLength": 1
        },
        "task_profile": {
          "type": "object",
          "properties": {
            "objective": {
              "type": "string",
              "enum": ["plan", "execute", "critique", "summarize", "extract", "classify", "answer", "code", "rag_synthesis"]
            },
            "constraints": { "type": "object" },
            "preferences": { "type": "object" }
          },
          "required": ["objective"]
        },
        "max_steps_per_run": {
          "type": "integer",
          "minimum": 1,
          "maximum": 100
        },
        "capabilities": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "output_channels": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "planner_mode": {
          "type": "string",
          "enum": ["single", "critic", "multi"],
          "description": "Controls multi-viewpoint planning: single (default), critic (plan+review), multi (N planners+evaluator)"
        }
      },
      "additionalProperties": false
    },
    "agent_configure_output": {
      "type": "object",
      "required": ["agent_id", "updated_at"],
      "properties": {
        "agent_id": {
          "type": "string",
          "minLength": 1
        },
        "label": {
          "type": "string",
          "minLength": 1
        },
        "task_profile": {
          "type": "object",
          "properties": {
            "objective": {
              "type": "string",
              "enum": ["plan", "execute", "critique", "summarize", "extract", "classify", "answer", "code", "rag_synthesis"]
            },
            "constraints": { "type": "object" },
            "preferences": { "type": "object" }
          },
          "required": ["objective"]
        },
        "max_steps_per_run": {
          "type": "integer",
          "minimum": 1
        },
        "capabilities": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "output_channels": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "updated_at": {
          "type": "string",
          "format": "date-time"
        }
      },
      "additionalProperties": false
    }
  }
}
