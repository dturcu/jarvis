{
  "annotations": { "list": [] },
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [],
  "panels": [
    {
      "title": "Job Throughput (rate/min)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
      "targets": [
        {
          "expr": "rate(jarvis_job_total[1m])",
          "legendFormat": "{{job_type}} ({{status}})"
        }
      ]
    },
    {
      "title": "Job Duration p50 / p95 / p99",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 },
      "targets": [
        { "expr": "histogram_quantile(0.5, rate(jarvis_job_duration_seconds_bucket[5m]))", "legendFormat": "p50" },
        { "expr": "histogram_quantile(0.95, rate(jarvis_job_duration_seconds_bucket[5m]))", "legendFormat": "p95" },
        { "expr": "histogram_quantile(0.99, rate(jarvis_job_duration_seconds_bucket[5m]))", "legendFormat": "p99" }
      ]
    },
    {
      "title": "Worker Health",
      "type": "gauge",
      "gridPos": { "h": 6, "w": 12, "x": 0, "y": 8 },
      "targets": [
        { "expr": "jarvis_worker_health_ratio", "legendFormat": "{{worker_prefix}}" }
      ],
      "fieldConfig": {
        "defaults": { "min": 0, "max": 1, "thresholds": { "steps": [
          { "color": "red", "value": 0 },
          { "color": "yellow", "value": 0.5 },
          { "color": "green", "value": 0.9 }
        ]}}
      }
    },
    {
      "title": "Queue Depth",
      "type": "timeseries",
      "gridPos": { "h": 6, "w": 12, "x": 12, "y": 8 },
      "targets": [
        { "expr": "jarvis_queue_depth", "legendFormat": "{{priority}}" }
      ]
    },
    {
      "title": "Model Latency (seconds)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 14 },
      "targets": [
        { "expr": "histogram_quantile(0.95, rate(jarvis_model_latency_seconds_bucket[5m]))", "legendFormat": "{{model_id}} ({{runtime}})" }
      ]
    },
    {
      "title": "Error Rate by Worker",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 14 },
      "targets": [
        {
          "expr": "rate(jarvis_job_total{status=\"failed\"}[5m]) / rate(jarvis_job_total[5m])",
          "legendFormat": "{{job_type}}"
        }
      ]
    }
  ],
  "schemaVersion": 39,
  "tags": ["jarvis", "observability"],
  "templating": { "list": [] },
  "time": { "from": "now-1h", "to": "now" },
  "title": "Jarvis Overview",
  "uid": "jarvis-overview"
}
