# ============================================================================
# Jarvis Configuration — Environment Variables
# ============================================================================
# Copy this file to .env and fill in your values.
# All variables are optional — Jarvis works with sensible defaults.
#
# For a guided setup, run: npm run jarvis setup
# ============================================================================

# ─── Core Settings ──────────────────────────────────────────────────────────

# Port for the Jarvis dashboard (default: 4242)
PORT=4242

# LM Studio base URL (default: http://localhost:1234)
LMS_URL=http://localhost:1234

# Default model to use (default: auto — picks best available)
LMS_MODEL=auto

# llama.cpp server base URL (default: http://localhost:8080)
# LLAMACPP_URL=http://localhost:8080

# ─── Runtime Binary Paths (auto-detected if not set) ──────────────────────
# OLLAMA_PATH=/path/to/ollama
# LMS_PATH=/path/to/lms
# LLAMACPP_PATH=/path/to/llama-server
# LLAMACPP_GGUF_DIRS=/path/to/models:/another/path   (colon-separated)

# Project root for file operations (default: current directory)
# JARVIS_PROJECT_ROOT=/path/to/your/project

# CORS origin for dashboard API (default: http://localhost:4242)
# JARVIS_CORS_ORIGIN=http://localhost:4242

# ─── Authentication ─────────────────────────────────────────────────────────

# API token for dashboard authentication (leave empty for dev mode — no auth)
# In production, generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# JARVIS_API_TOKEN=your-secret-token-here

# ─── Telegram Integration ──────────────────────────────────────────────────

# Get these from @BotFather on Telegram
# JARVIS_TELEGRAM_BOT_TOKEN=123456:ABC-DEF1234ghIkl-zyx57W2v1u123ew11
# JARVIS_TELEGRAM_CHAT_ID=123456789

# ─── Webhook Security ──────────────────────────────────────────────────────

# HMAC secret for authenticating incoming webhooks
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# JARVIS_WEBHOOK_SECRET=your-webhook-secret-here

# ─── Gmail Integration ─────────────────────────────────────────────────────
# Configure via: npm run jarvis setup gmail
# These are set in ~/.jarvis/config.json, not here.

# ─── Chrome Automation ──────────────────────────────────────────────────────
# Start Chrome with: chrome.exe --remote-debugging-port=9222
# Configure via: npm run jarvis setup chrome
